    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/unleash-react.js",
      "require": "./dist/unleash-react.umd.cjs"
    }
  },
  "browser": "./dist/unleash-react.umd.cjs",
  "files": [
    "dist",
    "LICENCE.txt"
  ],
