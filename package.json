    "@vitest/coverage-istanbul": "^3.2.4",
    "jsdom": "^23.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-test-renderer": "^18.2.0",
    "typescript": "^5.3.2",
    "unleash-proxy-client": "3.8.0-beta.3",
    "unplugin-dts": "^1.0.1",
    "vite": "6.4.2",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "unleash-proxy-client": "3.8.0-beta.3"
  },
